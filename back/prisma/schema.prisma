datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha  String
  createdAt DateTime @default(now())

  avaliacoes Avaliacao[]
}

model Player {
  id        String   @id @default(cuid())
  nome      String
  idade       Int
  posicao  String
  time     String
  pais   String
  createdAt DateTime @default(now())

  avaliacoes Avaliacao[]
}

model Avaliacao {
  id            String   @id @default(cuid())
  rating        Int      
  velocidade    Int      
  drible        Int      
  passe         Int      
  defesa        Int      
  físico        Int      
  comment       String?

  createdAt DateTime @default(now())

  userId   String
  playerId String

  user   User   @relation(fields: [userId], references: [id])
  player Player @relation(fields: [playerId], references: [id])
}