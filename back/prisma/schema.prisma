datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  avaliacoes Avaliacao[]
}

model Player {
  id        String   @id @default(cuid())
  name      String
  age       Int
  position  String
  team      String
  country   String
  createdAt DateTime @default(now())

  avaliacoes Avaliacao[]
}

model Avaliacao {
  id        String   @id @default(cuid())
  rating    Int      // nota geral (0 a 10)
  speed     Int      // velocidade
  dribble   Int      // drible
  pass      Int      // passe
  defense   Int      // defesa
  physical  Int      // físico
  comment   String?

  createdAt DateTime @default(now())

  userId   String
  playerId String

  user   User   @relation(fields: [userId], references: [id])
  player Player @relation(fields: [playerId], references: [id])
}